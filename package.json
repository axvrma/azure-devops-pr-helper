{
    "name": "azure-devops-pr-helper",
    "displayName": "Azure DevOps PR Helper",
    "publisher": "mrcreatist",
    "version": "0.1.0",
    "engines": {
        "vscode": "^1.60.0"
    },
    "activationEvents": [
        "onCommand:extension.raisePR",
        "onCommand:extension.copyPrUrl",
        "onCommand:extension.clearPAT",
        "onCommand:extension.openClaudeSettings",
        "onCommand:extension.generateClaudeTitle",
        "onCommand:extension.openClaudeSidebarSettings",
        "onView:claudeSidebarView"
    ],
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/node": "^24.0.4",
        "@types/vscode": "^1.101.0",
        "typescript": "^4.5.4",
        "vscode-test": "^1.6.1"
    },
    "dependencies": {
        "axios": "^0.27.2"
    },
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "extension.raisePR",
                "title": "Raise PR (Azure DevOps)",
                "category": "Azure DevOps"
            },
            {
                "command": "extension.copyPrUrl",
                "title": "Copy Last PR URL",
                "category": "Azure DevOps"
            },
            {
                "command": "extension.clearPAT",
                "title": "Clear Azure DevOps PAT",
                "category": "Azure DevOps"
            },
            {
                "command": "extension.openClaudeSettings",
                "title": "Open Claude & DevOps Settings",
                "category": "Azure DevOps"
            },
            {
                "command": "extension.generateClaudeTitle",
                "title": "Generate Claude PR Title",
                "category": "Azure DevOps"
            },
            {
                "command": "extension.openClaudeSidebarSettings",
                "title": "Open Claude Sidebar Settings",
                "category": "Azure DevOps"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "azureDevopsPr",
                    "title": "DevOps PR",
                    "icon": "resources/icon.png"
                }
            ]
        },
        "views": {
            "azureDevopsPr": [
                {
                    "icon": "resources/icon.png",
                    "id": "claudeSidebarView",
                    "name": "Claude Title Generator"
                }
            ]
        },
        "configuration": {
            "title": "Azure DevOps PR Helper",
            "properties": {
                "azureDevopsPr.orgHost": {
                    "type": "string",
                    "default": "https://dpwhotfsonline.visualstudio.com",
                    "description": "Default Azure DevOps organization URL (Host)."
                },
                "azureDevopsPr.project": {
                    "type": "string",
                    "default": "DTLP",
                    "description": "Default Azure DevOps project name."
                },
                "azureDevopsPr.useAI": {
                    "type": "boolean",
                    "default": true,
                    "description": "Use Claude AI to suggest PR title and description when creating a PR."
                },
                "azureDevopsPr.generateDescription": {
                    "type": "boolean",
                    "default": true,
                    "description": "When using AI, automatically generate a PR description as well as the title."
                },
                "azureDevopsPr.autoAcceptAI": {
                    "type": "boolean",
                    "default": false,
                    "description": "If true, automatically accept Claude-generated title/description without prompting the user."
                }
            }
        }
    }
}